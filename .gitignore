# .gitignore for .NET (Backend)

# Visual Studio cache
/.vs/

# Build artifacts
[Bb]in/
[Oo]bj/

# User-specific files
*.suo
*.user

# Environment files
.env

# Azure Publish Profiles
/Tutorz.Api/Properties/PublishProfiles/

# Logs
db_update_error.log

# Static Web Assets (excluding dynamic uploads)
# We ignore actual user-uploaded content but keep the folder structure
/Tutorz.Api/wwwroot/profile-pictures/*
/Tutorz.Api/wwwroot/qr-codes/*
!/Tutorz.Api/wwwroot/profile-pictures/.gitkeep
!/Tutorz.Api/wwwroot/qr-codes/.gitkeep

# NOTE: Migrations are NOT ignored. They MUST be tracked by Git.
